@page "/pdf-extractor"
@rendermode InteractiveServer
@using Company.App.Application.Shared
@using Company.App.Application.UseCases.DataExtraction.Models
@using Company.App.Application.UseCases.DataMapping.Models
@using Microsoft.AspNetCore.Components.Forms
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>PDF Extractor - Hero Compliance System</PageTitle>

<MudText Typo="Typo.h2" GutterBottom="true">
    <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Class="mr-2" />
    PDF Extractor
</MudText>
<MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-6">
    Generic PDF text extraction
</MudText>

<MudGrid>
    <MudItem xs="12" md="8">
        <MudPaper Elevation="4" Class="pa-6">
            <MudText Typo="Typo.h6" Class="mb-4">Upload PDF File</MudText>

            <MudFileUpload T="IBrowserFile"
                           @ref="_fileUpload"
                           Accept=".pdf,application/pdf"
                           OnFilesChanged="HandleFileSelected"
                           MaximumFileCount="1">
                <ButtonTemplate>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               HtmlTag="label"
                               Size="Size.Large"
                               FullWidth="true">
                        Select PDF File
                    </MudButton>
                </ButtonTemplate>
            </MudFileUpload>

            @if (_isProcessing)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
                <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2">
                    <em>Extracting text and line structure from PDF...</em>
                </MudText>
            }
            else if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4" Elevation="2">
                    @_errorMessage
                </MudAlert>
            }
            else if (_result?.IsSuccess == true && _document != null)
            {
                <MudAlert Severity="Severity.Success" Class="mt-4" Elevation="2">
                    <MudText Typo="Typo.h6">PDF extraction completed.</MudText>
                    <MudText Typo="Typo.body2" Class="mt-2">Document type: <strong>@(_documentTypeText ?? "Unknown")</strong></MudText>
                    <MudText Typo="Typo.body2" Class="mt-2">Words extracted: @_document.Words.Count</MudText>
                    <MudText Typo="Typo.body2">Lines extracted: @_document.Lines.Count</MudText>
                </MudAlert>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.h6" Class="mb-2">Preview of extracted lines</MudText>
                <MudText Typo="Typo.h6" Class="mb-2">Page|X|Y|Lenght|Text</MudText>

                @if (_document.Lines.Any())
                {
                    <MudPaper Outlined="true" Class="pa-4" Style="max-height: 400px; overflow-y: auto;">
                        @foreach (var line in _document.Lines.Take(10000))
                        {
                            <MudText Typo="Typo.body2" Class="mb-1">
                                <strong>@(line.PageNumber)</strong> | @line.X.ToString("F2") | @line.Y.ToString("F2") | @line.Width.ToString("F2") | @line.Text
                            </MudText>
                        }
                    </MudPaper>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        No lines were extracted from the file.
                    </MudText>
                }
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Elevation="4" Class="pa-6">
            <MudText Typo="Typo.h6" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                Instructions
            </MudText>

            <MudText Typo="Typo.body2" Class="mb-2">
                1. Select a PDF document
            </MudText>
            <MudText Typo="Typo.body2" Class="mb-2">
                2. The system extracts words and grouped lines
            </MudText>
            <MudText Typo="Typo.body2" Class="mb-2">
                3. No content-specific mapping is applied yet
            </MudText>
            <MudText Typo="Typo.body2">
                4. Review the extracted structure before domain mapping
            </MudText>

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.caption" Color="Color.Secondary">
                This page is intended as a generic PDF ingestion step before mapping into order models.
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private MudFileUpload<IBrowserFile>? _fileUpload;
    private bool _isProcessing;
    private string? _errorMessage;
    private Result<ExtractedDocumentDto>? _result;
    private ExtractedDocumentDto? _document;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        _isProcessing = true;
        _errorMessage = null;
        _result = null;
        _document = null;
        _mappingResult = null;
        _documentTypeText = null;
        StateHasChanged();

        try
        {
            var httpClient = HttpClientFactory.CreateClient("PdfExtractAPI");

            byte[] fileBytes;
            using (var stream = new MemoryStream())
            {
                await file.OpenReadStream(maxAllowedSize: 25 * 1024 * 1024).CopyToAsync(stream);
                fileBytes = stream.ToArray();
            }

            using (var extractContent = new MultipartFormDataContent())
            {
                var extractFileContent = new ByteArrayContent(fileBytes);
                extractFileContent.Headers.ContentType =
                    new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");

                extractContent.Add(extractFileContent, "file", file.Name);

                var extractUrl = new Uri(Navigation.BaseUri + "api/v1/order/extractPdf");
                var extractResponse = await httpClient.PostAsync(extractUrl, extractContent);

                if (extractResponse.IsSuccessStatusCode)
                {
                    _result = await extractResponse.Content.ReadFromJsonAsync<Result<ExtractedDocumentDto>>();
                    _document = _result?.Value;

                    if (_result is null || !_result.IsSuccess)
                    {
                        _errorMessage = _result?.Error ?? "PDF extraction failed.";
                    }
                }
                else
                {
                    var errorContent = await extractResponse.Content.ReadAsStringAsync();
                    _errorMessage = $"API error: {extractResponse.ReasonPhrase}. {errorContent}";
                }
            }

            if (string.IsNullOrWhiteSpace(_errorMessage))
            {
                using var mapContent = new MultipartFormDataContent();

                var mapFileContent = new ByteArrayContent(fileBytes);
                mapFileContent.Headers.ContentType =
                    new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");

                mapContent.Add(mapFileContent, "file", file.Name);

                var mapUrl = new Uri(Navigation.BaseUri + "api/v1/order/mapDocument");
                var mapResponse = await httpClient.PostAsync(mapUrl, mapContent);

                if (mapResponse.IsSuccessStatusCode)
                {
                    _mappingResult = await mapResponse.Content.ReadFromJsonAsync<Result<DocumentMappingResultDto>>();

                    if (_mappingResult?.Value is not null)
                    {
                        _documentTypeText = _mappingResult.Value.DocumentType.ToString();
                    }
                    else if (_mappingResult is not null && !_mappingResult.IsSuccess)
                    {
                        _documentTypeText = "Unknown";
                    }
                }
                else
                {
                    var errorContent = await mapResponse.Content.ReadAsStringAsync();
                    _errorMessage = $"Mapping API error: {mapResponse.ReasonPhrase}. {errorContent}";
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }

        _isProcessing = false;
        StateHasChanged();
    }

    // Get DocumentType
    private Result<DocumentMappingResultDto>? _mappingResult;
    private string? _documentTypeText;
}