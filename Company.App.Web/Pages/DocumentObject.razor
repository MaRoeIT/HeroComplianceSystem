@page "/document-object"
@rendermode InteractiveServer
@using System.Text.Json
@using Company.App.Application.Shared
@using Company.App.Application.UseCases.DataMapping.Models
@using Microsoft.AspNetCore.Components.Forms
@using Company.App.Domain.Entities.OneSubSea
@using Company.App.Application.UseCases.DataMapping.Helper
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Document Object - Hero Compliance System</PageTitle>

<MudText Typo="Typo.h2" GutterBottom="true">
    <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" />
    Document Object
</MudText>
<MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-6">
    Upload one or more PDF files and render grouped mapped document objects
</MudText>

<MudGrid>
    <MudItem xs="12" md="8">
        <MudPaper Elevation="4" Class="pa-6">
            <MudText Typo="Typo.h6" Class="mb-4">Upload PDF Files</MudText>

            <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                           @ref="_fileUpload"
                           Accept=".pdf,application/pdf"
                           OnFilesChanged="HandleFilesSelected"
                           MaximumFileCount="20">
                <ActivatorContent>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               OnClick="OpenFilePicker"
                               Size="Size.Large"
                               FullWidth="true">
                        Select PDF Files
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>

            @if (_isProcessing)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
                <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2">
                    <em>Mapping PDF files into document objects...</em>
                </MudText>
            }
            else if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4" Elevation="2">
                    @_errorMessage
                </MudAlert>
            }

            @if (!_isProcessing && _administrativeRequirementsGroup?.Parent is not null)
            {
                <MudAlert Severity="Severity.Success" Class="mt-4" Elevation="2">
                    <MudText Typo="Typo.h6">Administrative Requirements group</MudText>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        Parent file: <strong>@_administrativeRequirementsGroup.Parent.FileName</strong>
                    </MudText>
                </MudAlert>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.h6" Class="mb-2">Administrative Requirements</MudText>
                <MudPaper Outlined="true" Class="pa-4 mb-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                        @_administrativeRequirementsGroup.Parent.FileName (@_administrativeRequirementsGroup.Parent.DocumentType)
                    </MudText>

                    @if (_administrativeRequirementsGroup.Parent.Payload.HasValue)
                    {
                        @RenderJsonNode(_administrativeRequirementsGroup.Parent.FileName, _administrativeRequirementsGroup.Parent.Payload.Value)
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            No mapped payload was returned from the API.
                        </MudText>
                    }
                </MudPaper>
            }
            else if (!_isProcessing && _administrativeRequirementsGroup?.Appendices.Any() == true)
            {
                <MudAlert Severity="Severity.Warning" Class="mt-4" Elevation="2">
                    <MudText Typo="Typo.h6">Administrative appendices found without a parent Administrative Requirements document.</MudText>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        The appendix files were mapped successfully, but no parent file of type <strong>@DocumentType.AdministrativeRequirements</strong> was uploaded.
                    </MudText>
                </MudAlert>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.h6" Class="mb-2">Administrative appendices without parent</MudText>

                @foreach (var appendix in _administrativeRequirementsGroup.Appendices)
                {
                    <MudPaper Outlined="true" Class="pa-4 mb-4">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                            @appendix.FileName (@appendix.DocumentType)
                        </MudText>

                        @if (appendix.Payload.HasValue)
                        {
                            @RenderJsonNode(appendix.FileName, appendix.Payload.Value)
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                No mapped payload was returned from the API.
                            </MudText>
                        }
                    </MudPaper>
                }
            }

            @if (!_isProcessing && _independentDocuments.Any())
            {
                <MudDivider Class="my-4" />

                <MudText Typo="Typo.h6" Class="mb-2">Independent documents</MudText>

                @foreach (var document in _independentDocuments)
                {
                    <MudPaper Outlined="true" Class="pa-4 mb-4">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                            @document.FileName (@document.DocumentType)
                        </MudText>

                        @if (document.Payload.HasValue)
                        {
                            @RenderJsonNode(document.FileName, document.Payload.Value)
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                No mapped payload was returned from the API.
                            </MudText>
                        }
                    </MudPaper>
                }
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Elevation="4" Class="pa-6">
            <MudText Typo="Typo.h6" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                Instructions
            </MudText>

            <MudText Typo="Typo.body2" Class="mb-2">
                1. Select one or more PDF documents
            </MudText>
            <MudText Typo="Typo.body2" Class="mb-2">
                2. The system identifies each document type separately
            </MudText>
            <MudText Typo="Typo.body2" Class="mb-2">
                3. Administrative appendices are grouped under Administrative Requirements when a parent exists
            </MudText>
            <MudText Typo="Typo.body2">
                4. Other mapped document values are rendered as independent results
            </MudText>

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.caption" Color="Color.Secondary">
                This page is intended to inspect the structured result after document mapping and grouping.
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private static readonly JsonSerializerOptions _jsonOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    private MudFileUpload<IReadOnlyList<IBrowserFile>>? _fileUpload;
    private bool _isProcessing;
    private string? _errorMessage;
    private List<MappedDocumentViewModel> _independentDocuments = new();
    private AdministrativeRequirementsGroupViewModel? _administrativeRequirementsGroup;

    private sealed class MappedDocumentViewModel
    {
        public string FileName { get; set; } = string.Empty;
        public DocumentType DocumentType { get; set; }
        public JsonElement? Payload { get; set; }
    }

    private sealed class AdministrativeRequirementsGroupViewModel
    {
        public MappedDocumentViewModel? Parent { get; set; }
        public List<MappedDocumentViewModel> Appendices { get; set; } = new();
    }

    private async Task OpenFilePicker()
    {
        if (_fileUpload is not null)
        {
            await _fileUpload.OpenFilePickerAsync();
        }
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(20);

        _isProcessing = true;
        _errorMessage = null;
        _independentDocuments.Clear();
        _administrativeRequirementsGroup = new AdministrativeRequirementsGroupViewModel();

        StateHasChanged();

        try
        {
            foreach (var file in files)
            {
                var mappedDocument = await MapSingleFile(file);

                if (mappedDocument is null)
                    continue;

                if (mappedDocument.DocumentType == DocumentType.AdministrativeRequirements)
                {
                    _administrativeRequirementsGroup.Parent = mappedDocument;
                }
                else if (IsAdministrativeAppendixType(mappedDocument.DocumentType))
                {
                    _administrativeRequirementsGroup.Appendices.Add(mappedDocument);
                }
                else
                {
                    _independentDocuments.Add(mappedDocument);
                }
            }

            if (_administrativeRequirementsGroup.Parent?.Payload is JsonElement parentJson)
            {
                var parent = JsonSerializer.Deserialize<AdministrativeRequirements>(
                    parentJson.GetRawText(),
                    _jsonOptions);

                if (parent is not null)
                {
                    var appendices = _administrativeRequirementsGroup.Appendices
                        .Where(a => a.Payload.HasValue)
                        .SelectMany(a =>
                            JsonSerializer.Deserialize<List<AppendicesHeader>>(
                                a.Payload!.Value.GetRawText(),
                                _jsonOptions) ?? new List<AppendicesHeader>())
                        .ToList();

                    var mergedParent = AdministrativeRequirementsAssembler.AttachAppendices(parent, appendices);

                    _administrativeRequirementsGroup.Parent.Payload =
                        JsonSerializer.SerializeToElement(mergedParent, _jsonOptions);

                    _administrativeRequirementsGroup.Appendices.Clear();
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task<MappedDocumentViewModel?> MapSingleFile(IBrowserFile file)
    {
        var httpClient = HttpClientFactory.CreateClient("PdfExtractAPI");

        byte[] fileBytes;
        using (var stream = new MemoryStream())
        {
            await file.OpenReadStream(maxAllowedSize: 25 * 1024 * 1024).CopyToAsync(stream);
            fileBytes = stream.ToArray();
        }

        using var mapContent = new MultipartFormDataContent();

        var mapFileContent = new ByteArrayContent(fileBytes);
        mapFileContent.Headers.ContentType =
            new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");

        mapContent.Add(mapFileContent, "file", file.Name);

        var mapUrl = new Uri(Navigation.BaseUri + "api/v1/order/mapDocument");
        var mapResponse = await httpClient.PostAsync(mapUrl, mapContent);

        if (!mapResponse.IsSuccessStatusCode)
        {
            var errorContent = await mapResponse.Content.ReadAsStringAsync();
            throw new InvalidOperationException(
                $"Mapping API error for '{file.Name}': {mapResponse.ReasonPhrase}. {errorContent}");
        }

        var mappingResult = await mapResponse.Content.ReadFromJsonAsync<Result<DocumentMappingResultDto>>();

        if (mappingResult is null)
            throw new InvalidOperationException($"No response content was returned for '{file.Name}'.");

        if (!mappingResult.IsSuccess || mappingResult.Value is null)
            throw new InvalidOperationException(
                $"Document mapping failed for '{file.Name}': {mappingResult.Error ?? "Unknown error."}");

        JsonElement? payload = null;

        if (mappingResult.Value.MappedPayload is JsonElement json)
            payload = json;

        return new MappedDocumentViewModel
        {
            FileName = file.Name,
            DocumentType = mappingResult.Value.DocumentType,
            Payload = payload
        };
    }

    private static bool IsAdministrativeAppendixType(DocumentType documentType)
    {
        return documentType is
            DocumentType.HSSERequirementsForSuppliers or
            DocumentType.SupplierFinalInspectionSpecification or
            DocumentType.SupplierPackingMarkingandShippingInstruction or
            DocumentType.TraceabilitySpecificationForSuppliers or
            DocumentType.SupplierDocumentationSpecification or
            DocumentType.SpecialrequirementForPosreceivedFromBrazil;
    }

    private RenderFragment RenderJsonNode(string name, JsonElement element) => builder =>
    {
        int seq = 0;

        switch (element.ValueKind)
        {
            case JsonValueKind.Object:
                builder.OpenComponent<MudPaper>(seq++);
                builder.AddAttribute(seq++, "Class", "pa-3 mb-3");
                builder.AddAttribute(seq++, "Outlined", true);
                builder.AddAttribute(seq++, "ChildContent", (RenderFragment)((objectBuilder) =>
                {
                    int innerSeq = 0;

                    objectBuilder.OpenComponent<MudText>(innerSeq++);
                    objectBuilder.AddAttribute(innerSeq++, "Typo", Typo.h6);
                    objectBuilder.AddAttribute(innerSeq++, "ChildContent", (RenderFragment)((titleBuilder) =>
                    {
                        titleBuilder.AddContent(0, name);
                    }));
                    objectBuilder.CloseComponent();

                    foreach (var property in element.EnumerateObject())
                    {
                        objectBuilder.AddContent(innerSeq++, RenderJsonProperty(property.Name, property.Value));
                    }
                }));
                builder.CloseComponent();
                break;

            case JsonValueKind.Array:
                builder.OpenComponent<MudPaper>(seq++);
                builder.AddAttribute(seq++, "Class", "pa-3 mb-3");
                builder.AddAttribute(seq++, "Outlined", true);
                builder.AddAttribute(seq++, "ChildContent", (RenderFragment)((arrayBuilder) =>
                {
                    int innerSeq = 0;

                    arrayBuilder.OpenComponent<MudText>(innerSeq++);
                    arrayBuilder.AddAttribute(innerSeq++, "Typo", Typo.h6);
                    arrayBuilder.AddAttribute(innerSeq++, "ChildContent", (RenderFragment)((titleBuilder) =>
                    {
                        titleBuilder.AddContent(0, $"{name} [{element.GetArrayLength()}]");
                    }));
                    arrayBuilder.CloseComponent();

                    int index = 0;
                    foreach (var item in element.EnumerateArray())
                    {
                        arrayBuilder.AddContent(innerSeq++, RenderJsonNode($"{name}[{index}]", item));
                        index++;
                    }
                }));
                builder.CloseComponent();
                break;

            default:
                builder.OpenComponent<MudText>(seq++);
                builder.AddAttribute(seq++, "Typo", Typo.body2);
                builder.AddAttribute(seq++, "Class", "mb-1");
                builder.AddAttribute(seq++, "ChildContent", (RenderFragment)((valueBuilder) =>
                {
                    valueBuilder.AddMarkupContent(0, $"<strong>{name}:</strong> {FormatJsonValue(element)}");
                }));
                builder.CloseComponent();
                break;
        }
    };

    private RenderFragment RenderJsonProperty(string propertyName, JsonElement propertyValue) => builder =>
    {
        builder.AddContent(0, RenderJsonNode(propertyName, propertyValue));
    };

    private static string FormatJsonValue(JsonElement element)
    {
        return element.ValueKind switch
        {
            JsonValueKind.String => element.GetString() ?? string.Empty,
            JsonValueKind.Number => element.ToString(),
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            JsonValueKind.Null => "null",
            _ => element.ToString()
        };
    }
}