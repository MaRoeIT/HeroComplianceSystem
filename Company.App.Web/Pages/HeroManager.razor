@page "/hero-manager"
@rendermode InteractiveServer
@using Company.App.Application.Shared
@using Company.App.Application.UseCases.DetectBatman.Models
@using Company.App.Application.UseCases.LookupHeroByName
@using System.Net.Http.Json
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Hero Manager - Hero Compliance System</PageTitle>

<MudText Typo="Typo.h2" GutterBottom="true">
    <MudIcon Icon="@Icons.Material.Filled.SupervisedUserCircle" Class="mr-2" /> Hero Manager
</MudText>
<MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-6">Add and Search Heroes</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Elevation="4" Class="pa-6">
            <MudText Typo="Typo.h5" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" /> Add New Hero
            </MudText>
            
            <MudForm @ref="_addForm" Class="mt-4">
                <MudTextField @bind-Value="_newHeroName"
                              Label="Hero Name"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Hero name is required"
                              Class="mb-4" />
                
                <MudTextField @bind-Value="_newHeroIdentity"
                              Label="Secret Identity"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Secret identity is required"
                              Class="mb-4" />
                
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddHeroAsync"
                           Disabled="_isAdding"
                           FullWidth="true"
                           Size="Size.Large">
                    @if (_isAdding)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <text>Adding...</text>
                    }
                    else
                    {
                        <text>Add Hero</text>
                    }
                </MudButton>
            </MudForm>

            @if (_addResult != null)
            {
                <MudAlert Severity="@(_addResult.IsSuccess ? Severity.Success : Severity.Error)"
                          Class="mt-4"
                          Elevation="2"
                          CloseIconClicked="() => _addResult = null"
                          CloseIcon="@Icons.Material.Filled.Close">
                    @if (_addResult.IsSuccess)
                    {
                        <MudText Typo="Typo.body1">✅ Hero added successfully!</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body1">❌ @_addResult.Error</MudText>
                    }
                </MudAlert>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Elevation="4" Class="pa-6">
            <MudText Typo="Typo.h5" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-2" /> Find Hero
            </MudText>
            
            <MudForm @ref="_searchForm" Class="mt-4">
                <MudTextField @bind-Value="_searchName"
                              Label="Hero Name"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Hero name is required"
                              Class="mb-4"
                              OnKeyDown="@(async (e) => { if (e.Key == "Enter") await FindHeroAsync(); })" />
                
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search"
                           OnClick="FindHeroAsync"
                           Disabled="_isSearching"
                           FullWidth="true"
                           Size="Size.Large">
                    @if (_isSearching)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <text>Searching...</text>
                    }
                    else
                    {
                        <text>Find</text>
                    }
                </MudButton>
            </MudForm>

            @if (_searchResult != null)
            {
                @if (_searchResult.Value?.Found == true)
                {
                    <MudAlert Severity="Severity.Success"
                              Class="mt-4"
                              Elevation="2">
                        <MudText Typo="Typo.h6" GutterBottom="true">🦸 Hero Found!</MudText>
                        <MudText><strong>Name:</strong> @_searchResult.Value.Name</MudText>
                        <MudText><strong>Secret Identity:</strong> @_searchResult.Value.SecretIdentity</MudText>
                        <MudText Class="mt-2" Typo="Typo.caption">
                            Last Updated: @_searchResult.Value.LastUpdatedAt.ToString("g")
                        </MudText>
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Warning"
                              Class="mt-4"
                              Elevation="2"
                              CloseIconClicked="() => _searchResult = null"
                              CloseIcon="@Icons.Material.Filled.Close">
                        <MudText Typo="Typo.body1">🔍 No hero found with the name "@_searchName"</MudText>
                    </MudAlert>
                }
            }
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Elevation="4" Class="pa-6 mt-6">
    <MudText Typo="Typo.h5" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.Group" Class="mr-2" /> All Heroes
    </MudText>

    @if (_isLoadingHeroes)
    {
        <MudProgressCircular Indeterminate="true" Class="my-4" />
        <MudText>Loading heroes...</MudText>
    }
    else if (_allHeroesResult != null && _allHeroesResult.IsSuccess && _allHeroesResult.Value?.Count > 0)
    {
        <MudGrid Class="mt-4">
            @foreach (var hero in _allHeroesResult.Value)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@hero.Name</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudIcon Icon="@Icons.Material.Filled.SupervisedUserCircle" Color="Color.Primary" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2"><strong>Secret Identity:</strong></MudText>
                            <MudText Typo="Typo.body2" Class="mb-2">@hero.SecretIdentity</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Updated: @hero.LastUpdatedAt.ToString("g")
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (_allHeroesResult?.Value?.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">
            <MudText>No heroes found in the database. Add some heroes to get started!</MudText>
        </MudAlert>
    }
    else if (_allHeroesResult != null && !_allHeroesResult.IsSuccess)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">
            <MudText>Error loading heroes: @_allHeroesResult.Error</MudText>
        </MudAlert>
    }
</MudPaper>

    @code {
    private MudForm? _addForm;
    private MudForm? _searchForm;

    private string _newHeroName = string.Empty;
    private string _newHeroIdentity = string.Empty;
    private string _searchName = string.Empty;

    private bool _isAdding = false;
    private bool _isSearching = false;
    private bool _isLoadingHeroes = false;

    private Result? _addResult;
    private Result<HeroByNameResult>? _searchResult;
    private Result<List<HeroByNameResult>>? _allHeroesResult;

    protected override async Task OnInitializedAsync()
    {
        await GetAllHeroes();
    }

    private async Task AddHeroAsync()
    {
        await _addForm!.ValidateAsync();

        if (!_addForm.IsValid)
            return;

        _isAdding = true;
        _addResult = null;

        try
        {
            var httpClient = HttpClientFactory.CreateClient();
            var heroDto = new HeroDto(_newHeroName, _newHeroIdentity, 0);

            var apiUrl = Navigation.ToAbsoluteUri("/api/v1/hero/heroes").ToString();
            var response = await httpClient.PostAsJsonAsync(apiUrl, heroDto);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<Result>();
                _addResult = result ?? new Result(false, "No response from server");

                if (_addResult.IsSuccess)
                {
                    _newHeroName = string.Empty;
                    _newHeroIdentity = string.Empty;
                    await _addForm.ResetAsync();
                }
            }
            else
            {
                _addResult = new Result(false, $"Server error: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            _addResult = new Result(false, $"Error adding hero: {ex.Message}");
        }
        finally
        {
            _isAdding = false;
            await GetAllHeroes();
        }
    }

    private async Task FindHeroAsync()
    {
        await _searchForm!.ValidateAsync();

        if (!_searchForm.IsValid)
            return;

        _isSearching = true;
        _searchResult = null;

        try
        {
            var httpClient = HttpClientFactory.CreateClient();
            var apiUrl = Navigation.ToAbsoluteUri($"/api/v1/hero/heroes/{_searchName}").ToString();
            var response = await httpClient.GetAsync(apiUrl);

            if (response.IsSuccessStatusCode)
            {
                _searchResult = await response.Content.ReadFromJsonAsync<Result<HeroByNameResult>>();
            }
            else
            {
                _searchResult = new Result<HeroByNameResult>(null, false, $"Server error: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            _searchResult = new Result<HeroByNameResult>(null, false, $"Error searching: {ex.Message}");
        }
        finally
        {
            _isSearching = false;
        }
    }

    private async Task GetAllHeroes()
    {
        _isLoadingHeroes = true;
        try
        {
            var httpClient = HttpClientFactory.CreateClient();
            var apiUrl = Navigation.ToAbsoluteUri($"/api/v1/hero/heroes").ToString();
            var response = await httpClient.GetAsync(apiUrl);
            if(response.IsSuccessStatusCode)
            {
                _allHeroesResult = await response.Content.ReadFromJsonAsync<Result<List<HeroByNameResult>>>();
            }
            else
            {
                _allHeroesResult = new Result<List<HeroByNameResult>>(null, false, $"Server error: {response.StatusCode}");
            }
        }
        catch(Exception ex)
        {
            _allHeroesResult = new Result<List<HeroByNameResult>>(null, false, $"Error fetching heroes: {ex.Message}");
        }
        finally
        {
            _isLoadingHeroes = false;
        }
    }
}
